                    },
                    "<BackgroundHolder>k__BackingField": {
                        "<BackgroundId>k__BackingField": {
                            "_value": "75ea9262-de6f-44cb-a8db-15d561f8490a"
                        }
                    },
                    "<ActorsHolder>k__BackingField": {
                        "rid": 1014
                    },
                    "<Position>k__BackingField": {
                        "x": 2397.813720703125,
