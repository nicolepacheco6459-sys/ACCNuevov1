                    "<Position>k__BackingField": {
                        "x": 1901.88232421875,
                        "y": 194.0197296142578
                    },
                    "<NextNode>k__BackingField": {
                        "_value": "5086cb55-237c-44da-ac89-4c471076584e"
                    },
                    "<Text>k__BackingField": "El camino hacia la ciudad fue largo. Las carreteras parecían interminables y por momentos pensé en regresar. Cada kilómetro hacía que todo se sintiera más real. La granja, los campos, los años que había pasado ahí… poco a poco comenzaban a quedarse atrás."
                }
            },
            {
                "rid": 1006,
                "type": {
                    "class": "DialogueReplicaNodeData",
                    "ns": "KissMyAssets.VisualNovelCore.Runtime",
