                        "_value": "e74086a7-5022-42f6-b29c-a7a7c4becda0"
                    },
                    "<Text>k__BackingField": "Empacar tomó menos tiempo del que esperaba. Después de todo, no había demasiadas cosas que quisiera llevar conmigo.\r\n"
                }
            },
            {
                "rid": 1003,
                "type": {
                    "class": "DialogueReplicaNodeData",
                    "ns": "KissMyAssets.VisualNovelCore.Runtime",
                    "asm": "Assembly-CSharp"
                },
                "data": {
                    "<NodeId>k__BackingField": {
                        "_value": "e74086a7-5022-42f6-b29c-a7a7c4becda0"
                    },
                    "<BackgroundHolder>k__BackingField": {
                        "<BackgroundId>k__BackingField": {
                            "_value": "1df4df82-0676-4f92-a8e7-083d4948c541"
                        }
                    },
                    "<ActorsHolder>k__BackingField": {
                        "rid": 1011
                    },
                    "<Position>k__BackingField": {
                        "x": 941.978759765625,
                        "y": 216.32980346679688
                    },
                    "<NextNode>k__BackingField": {
                        "_value": "24cb7a77-d65f-4c08-96f8-d73ea3aac52d"
                    },
                    "<Text>k__BackingField": "Lo difícil no fue hacer la maleta.\n\n\r\nLo difícil fue cerrar la puerta de la casa por última vez.\r\n"
                }
            },
            {
                "rid": 1004,
                "type": {
                    "class": "DialogueReplicaNodeData",
                    "ns": "KissMyAssets.VisualNovelCore.Runtime",
                    "asm": "Assembly-CSharp"
                },
                "data": {
                    "<NodeId>k__BackingField": {
                        "_value": "24cb7a77-d65f-4c08-96f8-d73ea3aac52d"
                    },
                    "<BackgroundHolder>k__BackingField": {
                        "<BackgroundId>k__BackingField": {
                            "_value": "97467b5b-a090-42f4-b992-0f9926914ade"
                        }
                    },
                    "<ActorsHolder>k__BackingField": {
                        "rid": 1012
                    },
                    "<Position>k__BackingField": {
                        "x": 1420.340087890625,
                        "y": 185.44329833984376
                    },
                    "<NextNode>k__BackingField": {
                        "_value": "baf504e8-de7d-4ff8-af75-4f162196c7d9"
                    },
                    "<Text>k__BackingField": "Porque irme significaba aceptar algo que había tratado de evitar durante mucho tiempo: la vida que conocía había terminado, y aunque doliera seguir adelante… quedarme quieto no iba a cambiar nada.\r\n"
                }
            },
            {
                "rid": 1005,
                "type": {
                    "class": "DialogueReplicaNodeData",
                    "ns": "KissMyAssets.VisualNovelCore.Runtime",
                    "asm": "Assembly-CSharp"
                },
                "data": {
                    "<NodeId>k__BackingField": {
                        "_value": "baf504e8-de7d-4ff8-af75-4f162196c7d9"
                    },
                    "<BackgroundHolder>k__BackingField": {
                        "<BackgroundId>k__BackingField": {
                            "_value": "97467b5b-a090-42f4-b992-0f9926914ade"
                        }
                    },
                    "<ActorsHolder>k__BackingField": {
                        "rid": 1013
