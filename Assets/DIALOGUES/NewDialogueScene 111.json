                    },
                    "<NextNode>k__BackingField": {
                        "_value": "f5709fc7-c682-4b83-b1d9-c5f1e7375964"
                    },
                    "<Text>k__BackingField": "Y aun así, entre todo ese miedo y esa incertidumbre, había algo más."
                }
            },
