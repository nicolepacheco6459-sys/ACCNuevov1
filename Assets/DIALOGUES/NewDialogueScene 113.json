                    "<NodeId>k__BackingField": {
                        "_value": "4e6ac57e-6c95-4ea9-9cd1-38ed4cbc0c34"
                    },
                    "<BackgroundHolder>k__BackingField": {
                        "<BackgroundId>k__BackingField": {
                            "_value": "628f055e-8e87-42ab-8511-8f151f0eb11f"
                        }
                    },
                    "<ActorsHolder>k__BackingField": {
                        "rid": 1017
                    },
                    "<Position>k__BackingField": {
                        "x": 991.237060546875,
                        "y": -34.18556213378906
                    },
                    "<NextNode>k__BackingField": {
                        "_value": "aaa727b9-beda-47e9-a735-102049c37e43"
                    },
                    "<Text>k__BackingField": "Pero por primera vez en mucho tiempo, la decisión había sido mía.\n\r\nY eso era suficiente.\r\n"
                }
            },
            {
                "rid": 1005,
                "type": {
                    "class": "DialogueReplicaNodeData",
                    "ns": "KissMyAssets.VisualNovelCore.Runtime",
                    "asm": "Assembly-CSharp"
                },
                "data": {
                    "<NodeId>k__BackingField": {
                        "_value": "aaa727b9-beda-47e9-a735-102049c37e43"
                    },
                    "<BackgroundHolder>k__BackingField": {
                        "<BackgroundId>k__BackingField": {
                            "_value": "628f055e-8e87-42ab-8511-8f151f0eb11f"
