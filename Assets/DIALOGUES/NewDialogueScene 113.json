                        "_value": "2544c0b9-c9a9-4903-a037-17b1da42b578"
                    },
                    "<Text>k__BackingField": "No sabía exactamente qué iba a pasar después.\n\r\nNi si realmente encajaría en ese lugar.\r\n"
                }
            },
            {
                "rid": 1003,
                "type": {
                    "class": "DialogueReplicaNodeData",
