                    },
                    "<NextNode>k__BackingField": {
                        "_value": "13aec1a9-17dc-4ff4-bcef-c436dc8df60a"
                    },
                    "<Text>k__BackingField": "Y sin darme cuenta… yo también había empezado a cambiar.\n\r\nFue entonces cuando vi a alguien observándome a la distancia.\r\n"
                }
            },
            {
                "rid": 1007,
                "type": {
                    "class": "DialogueReplicaNodeData",
                    "ns": "KissMyAssets.VisualNovelCore.Runtime",
