                    "<NextNode>k__BackingField": {
                        "_value": "ffa53d38-5960-4425-a7b9-a4cacaebd552"
                    },
                    "<Text>k__BackingField": "Era extraño.\n\r\nPero también se sentía cálido.\r\n"
                }
            },
            {
                "rid": 1005,
                "type": {
                    "class": "DialogueReplicaNodeData",
