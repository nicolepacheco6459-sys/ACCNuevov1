                    },
                    "<Text>k__BackingField": "La ciudad era completamente distinta a cualquier lugar que hubiera visto antes.\n\r\nMás ruidosa. Más brillante. Más viva."
                }
            },
            {
                "rid": 1003,
                "type": {
